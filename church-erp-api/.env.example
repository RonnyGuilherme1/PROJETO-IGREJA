# Required variables for local and production environments.
NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/church_erp?schema=public"
# Separate multiple origins with commas.
# In development, use your local frontend URLs.
# In production, use only explicit frontend domains.
CORS_ORIGIN=http://localhost:3000,http://192.168.50.234:3000
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
# Optional. If omitted or left blank, uploads use {process.cwd()}/uploads.
# On Railway with Volume, mount it at /app/uploads and set UPLOAD_ROOT=/app/uploads.
UPLOAD_ROOT=

# Production / Railway minimum example:
# NODE_ENV=production
# PORT=3001
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
# CORS_ORIGIN=https://your-frontend-domain.up.railway.app
# JWT_SECRET=replace-with-a-long-random-secret
# JWT_EXPIRES_IN=1d
# UPLOAD_ROOT=/app/uploads
