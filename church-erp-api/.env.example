# Base example for local development.
# For Railway production, use production values for the same variables
# or copy the template from .env.production.example.
NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/church_erp?schema=public"
CORS_ORIGIN=http://localhost:3000,http://192.168.50.234:3000
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=1d
# Optional. When not set, uploads continue in <project>/uploads.
# In Railway, point this to the mounted Volume path, e.g. /data/uploads.
UPLOAD_ROOT=
