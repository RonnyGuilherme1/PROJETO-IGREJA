# Minimum environment variables for Railway production.
NODE_ENV=production
PORT=8080
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
CORS_ORIGIN=https://your-frontend-domain.com
JWT_SECRET=replace-with-a-strong-secret
JWT_EXPIRES_IN=1d

# Public API base used by master links, Hosted/Embedded Signup callback and public webhook.
# If your API runs under Nest global prefix, keep the public /api suffix here.
API_PUBLIC_URL=https://api.your-domain.com/api

# Public frontend base reserved for operator-facing redirects or deep links.
FRONTEND_PUBLIC_URL=https://your-frontend-domain.com

# Meta platform credentials. These are global platform secrets and must not be editable by tenants.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_CONFIG_ID=your-meta-business-login-config-id

# Meta public webhook verification token configured in the app dashboard.
META_VERIFY_TOKEN=your-meta-webhook-verify-token
