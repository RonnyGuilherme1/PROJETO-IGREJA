generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  SECRETARIA
  TESOUREIRO
  CONSULTA
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum TenantStatus {
  ACTIVE
  INACTIVE
}

enum PlatformRole {
  PLATFORM_ADMIN
  PLATFORM_OPERATOR
  PLATFORM_SUPPORT
}

enum ChurchStatus {
  ACTIVE
  INACTIVE
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum FinanceType {
  ENTRY
  EXPENSE
}

enum FinanceTransactionStatus {
  ACTIVE
  CANCELLED
}

enum CampaignStatus {
  ACTIVE
  CLOSED
}

enum CampaignInstallmentStatus {
  PAID
  UNPAID
}

enum NoticeStatus {
  DRAFT
  READY
  SENT
}

model Tenant {
  id                      String               @id @default(uuid()) @db.Uuid
  name                    String
  slug                    String               @unique
  status                  TenantStatus         @default(ACTIVE)
  logoUrl                 String?
  themeKey                String               @default("green")
  createdByPlatformUserId String?              @db.Uuid
  updatedByPlatformUserId String?              @db.Uuid
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  users                   User[]
  churches                Church[]
  members                 Member[]
  leadershipRoles         LeadershipRole[]
  departments             Department[]
  campaigns               Campaign[]
  notices                 Notice[]
  financeCategories       FinanceCategory[]
  financeTransactions     FinanceTransaction[]

  @@index([createdByPlatformUserId])
  @@index([updatedByPlatformUserId])
}

model User {
  id                         String               @id @default(uuid()) @db.Uuid
  name                       String
  username                   String?              @unique
  email                      String?              @unique
  passwordHash               String
  role                       UserRole             @default(CONSULTA)
  status                     UserStatus           @default(ACTIVE)
  tenantId                   String?              @db.Uuid
  tenant                     Tenant?              @relation(fields: [tenantId], references: [id])
  platformRole               PlatformRole?
  isSystemProtected          Boolean              @default(false)
  createdByPlatformUserId    String?              @db.Uuid
  churchId                   String?              @db.Uuid
  church                     Church?              @relation(fields: [churchId], references: [id])
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  financeTransactionsCreated FinanceTransaction[] @relation("FinanceTransactionCreatedBy")

  @@index([tenantId])
  @@index([churchId])
  @@index([createdByPlatformUserId])
}

model Church {
  id                  String               @id @default(uuid()) @db.Uuid
  tenantId            String?              @db.Uuid
  tenant              Tenant?              @relation(fields: [tenantId], references: [id])
  name                String
  cnpj                String?
  phone               String?
  email               String?
  address             String?
  pastorName          String?
  status              ChurchStatus         @default(ACTIVE)
  notes               String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  users               User[]
  members             Member[]
  campaigns           Campaign[]
  notices             Notice[]
  financeTransactions FinanceTransaction[]

  @@index([tenantId])
}

model Member {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String?         @db.Uuid
  tenant           Tenant?         @relation(fields: [tenantId], references: [id])
  fullName         String
  birthDate        DateTime?
  gender           String?
  phone            String?
  email            String?
  address          String?
  maritalStatus    String?
  joinedAt         DateTime?
  status           MemberStatus    @default(ACTIVE)
  notes            String?
  churchId         String          @db.Uuid
  leadershipRoleId String?         @db.Uuid
  departmentId     String?         @db.Uuid
  church           Church          @relation(fields: [churchId], references: [id])
  leadershipRole   LeadershipRole? @relation(fields: [leadershipRoleId], references: [id])
  department       Department?     @relation(fields: [departmentId], references: [id])
  campaignMembers  CampaignMember[]
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([tenantId])
  @@index([churchId])
  @@index([leadershipRoleId])
  @@index([departmentId])
  @@index([status])
}

model LeadershipRole {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @db.Uuid
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  members     Member[]

  @@index([tenantId])
  @@index([active])
  @@unique([tenantId, name])
}

model Department {
  id          String    @id @default(uuid()) @db.Uuid
  tenantId    String?   @db.Uuid
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  name        String
  description String?
  active      Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  members     Member[]

  @@index([tenantId])
  @@index([active])
  @@unique([tenantId, name])
}

model Campaign {
  id                String          @id @default(uuid()) @db.Uuid
  tenantId          String?         @db.Uuid
  churchId          String          @db.Uuid
  tenant            Tenant?         @relation(fields: [tenantId], references: [id])
  church            Church          @relation(fields: [churchId], references: [id])
  title             String
  description       String?
  installmentCount  Int
  installmentAmount Decimal         @db.Decimal(14, 2)
  startDate         DateTime?
  status            CampaignStatus  @default(ACTIVE)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  members           CampaignMember[]

  @@index([tenantId])
  @@index([churchId])
  @@index([status])
}

model CampaignMember {
  id           String               @id @default(uuid()) @db.Uuid
  campaignId   String               @db.Uuid
  memberId     String               @db.Uuid
  joinedAt     DateTime             @default(now())
  notes        String?
  campaign     Campaign             @relation(fields: [campaignId], references: [id])
  member       Member               @relation(fields: [memberId], references: [id])
  installments CampaignInstallment[]

  @@index([campaignId])
  @@index([memberId])
  @@unique([campaignId, memberId])
}

model CampaignInstallment {
  id               String                    @id @default(uuid()) @db.Uuid
  campaignMemberId String                    @db.Uuid
  installmentNumber Int
  amount           Decimal                   @db.Decimal(14, 2)
  dueDate          DateTime?
  status           CampaignInstallmentStatus @default(UNPAID)
  paidAt           DateTime?
  notes            String?
  campaignMember   CampaignMember            @relation(fields: [campaignMemberId], references: [id])

  @@index([campaignMemberId])
  @@index([status])
  @@index([dueDate])
  @@unique([campaignMemberId, installmentNumber])
}

model Notice {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String?      @db.Uuid
  churchId    String?      @db.Uuid
  tenant      Tenant?      @relation(fields: [tenantId], references: [id])
  church      Church?      @relation(fields: [churchId], references: [id])
  title       String
  message     String
  imageUrl    String?
  targetLabel String?
  scheduledAt DateTime?
  status      NoticeStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
  @@index([churchId])
  @@index([status])
  @@index([scheduledAt])
}

model FinanceCategory {
  id           String               @id @default(uuid()) @db.Uuid
  tenantId     String?              @db.Uuid
  tenant       Tenant?              @relation(fields: [tenantId], references: [id])
  name         String
  type         FinanceType
  active       Boolean              @default(true)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  transactions FinanceTransaction[]

  @@index([tenantId])
  @@index([type])
  @@index([active])
}

model FinanceTransaction {
  id              String                   @id @default(uuid()) @db.Uuid
  tenantId        String?                  @db.Uuid
  tenant          Tenant?                  @relation(fields: [tenantId], references: [id])
  churchId        String                   @db.Uuid
  categoryId      String                   @db.Uuid
  type            FinanceType
  description     String
  amount          Decimal                  @db.Decimal(14, 2)
  transactionDate DateTime
  notes           String?
  status          FinanceTransactionStatus @default(ACTIVE)
  createdByUserId String                   @db.Uuid
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  church          Church                   @relation(fields: [churchId], references: [id])
  category        FinanceCategory          @relation(fields: [categoryId], references: [id])
  createdByUser   User                     @relation("FinanceTransactionCreatedBy", fields: [createdByUserId], references: [id])

  @@index([tenantId])
  @@index([churchId])
  @@index([categoryId])
  @@index([type])
  @@index([transactionDate])
  @@index([status])
  @@index([createdByUserId])
}
